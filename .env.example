# Billy — single configuration file (copy to .env; .env is git-ignored).
# Bind-mount / single-.env model: one file configures the whole stack; edit +
# `docker compose restart` to apply — no rebuild. See development/infrastructure/
# env-vars_spec.md (the canonical registry). Frontend public config is injected
# at RUNTIME (config.js), never baked at build.
#
# Dev has safe defaults so the stack boots out of the box. In production every
# secret MUST be set to a strong generated value (see scripts/dev secret helper).

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development                 # development | production | test
APP_URL=http://localhost:3480       # public URL of the web app
API_URL=http://localhost:3480/api   # public URL of the API
PORT=3000
LOG_LEVEL=info                      # fatal|error|warn|info|debug|trace|silent

# ── Auth secrets (REQUIRED in production — generate strong values) ─────────────
SESSION_SECRET=dev-session-secret-change-me   # signs server-side session cookies (the real auth secret)
JWT_SECRET=dev-jwt-secret-change-me           # signs SHORT-LIVED tokens only (reset/verify/2FA) — NOT sessions

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/billy

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── MinIO / object storage ─────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=billy
MINIO_ROOT_USER=billy-admin
MINIO_ROOT_PASSWORD=change-me-in-env

# ── Observability ───────────────────────────────────────────────────────────────
METRICS_ENABLED=true

# ── SMTP / email (fallbacks; the Customization Panel overrides these in the DB) ──
# Unset SMTP_HOST → dev jsonTransport (composes, does NOT send). Set for real email.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=            # secret — encrypted at rest if set via the panel
SMTP_FROM_EMAIL=no-reply@billy.local
SMTP_FROM_NAME=Billy

# ── At-rest field encryption (REQUIRED in production) ───────────────────────────
# 32+ char key. Encrypts admin-set secrets (e.g. the SMTP password) at rest
# (encryption-at-rest ENC-4). LOSS = those encrypted fields are unrecoverable —
# back it up separately from the DB. Generate: `openssl rand -base64 32`.
DATA_ENCRYPTION_KEY=dev-data-encryption-key-change-me-please-0

# ── MinIO app credentials (the api/worker use these to reach object storage) ────
# In a single-operator self-host these may equal MINIO_ROOT_USER/PASSWORD.
MINIO_ACCESS_KEY=billy-admin
MINIO_SECRET_KEY=change-me-in-env
MINIO_ROOT_USER=billy-admin
MINIO_ROOT_PASSWORD=change-me-in-env

# ── First-run SYSADMIN bootstrap (one-time; rotate/remove after first boot) ─────
# If set, the GLOBAL sysadmin is created on first boot (the account manager: it
# creates accounts + their users). `scripts/setup.sh` prompts for these on install.
# Leave blank to create the sysadmin via the first-run flow in the UI instead.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# ── Deployment / Docker Compose (consumed by docker-compose*.yml) ───────────────
PROXY_HTTP_PORT=3480          # host port the proxy listens on (Billy uses 3480–3490)
PROXY_HTTPS_PORT=3481         # prod: host HTTPS port (set to 443 on a public host)
PUBLIC_HOST=localhost         # prod: the public hostname (TLS cert + routing)
ACME_EMAIL=admin@example.com  # prod: Let's Encrypt registration email
REDIS_PASSWORD=change-me-in-env   # prod: redis --requirepass
PDF_CONCURRENCY=2             # worker: max concurrent Chromium PDF renders
CLAMAV_ENABLED=true           # prod: upload AV scanning (false = hook no-ops)

# ── Backups (scripts/backup/backup.sh + the worker `backup` queue) ──────────────
BACKUP_DIR=./data/backups            # where encrypted archives are written
BACKUP_ENCRYPTION_KEY=               # REQUIRED to run backups — AES-256 passphrase (openssl)
BACKUP_RETENTION_DAYS=30             # prune archives older than this (keeps newest)
# BACKUP_SCHEDULE=0 3 * * *          # (prod) cron for the scheduled backup job

# ── Not yet wired (added as their subsystems land) ──────────────────────────────
# VAPID_PUBLIC_KEY / VAPID_PRIVATE_KEY (web push).

# Address autocomplete (Geoapify). Optional — get a free key at geoapify.com. The
# server proxies /api/v1/geo; the key never reaches the browser. Empty = feature off.
GEOAPIFY_API_KEY=
